{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "static/**",
      "use": "@vercel/static"
    },
    {
      "src": "landing/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/static/$1" },
    { "src": "/landing/(.*)", "dest": "/landing/$1" },
    { "src": "/landing", "dest": "/landing/index.html" },
    { "src": "/(.*)", "dest": "/api/index" }
  ]
}
